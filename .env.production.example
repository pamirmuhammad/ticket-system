# =========================================
# Production Environment Variables Reference
# =========================================
# Copy this file, rename to .env, fill values, then:
#   docker compose --env-file .env up -d
# =========================================

# --- Mandatory ---
JWT_SECRET=change-this-to-a-random-256-bit-string

# --- Database ---
DB_USERNAME=postgres
DB_PASSWORD=change-this-password

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Storage (local or s3) ---
STORAGE_TYPE=local
# S3_BUCKET=my-bucket
# S3_REGION=us-east-1
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key

# --- Email (SMTP) ---
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password

# --- Sentry (optional) ---
# SENTRY_DSN=https://your-dsn@o123456.ingest.sentry.io/1234567
# VITE_SENTRY_DSN=https://your-dsn@o123456.ingest.sentry.io/1234567
